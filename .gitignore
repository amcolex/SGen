# IDE / editor
/.idea/
/.bsp/
/.vscode/

# SBT / Scala build outputs
/project/target/
/project/project/
/target/

# Build / simulation artifacts
/build/
/xsim.dir/
/project_1/

# Verilator / C++ simulation working dirs
/sim/

# SGen self-test outputs (test/sim/sim.sh, test/synth/synth.sh generate many subdirs)
/test/sim/*/
/test/synth/*/

# Generated Verilog (regenerated by sgen.bat) and graph dumps
/*.v
/*.gv
/*.pdf
/*.svg

# Design generation outputs (regenerated by scripts/generate/*)
/designs/generated/
/designs/reference/*.v

# Synthesis / P&R outputs (regenerated by scripts/synth/*)
/reports/

# Ad-hoc synthesis scripts and docs from optimization experiments
/scripts/synth/libero/synth_*.tcl
/scripts/synth/libero/timing_*.sdc
/scripts/synth/libero/sgen_dftcompact_2048_4x18_merged_pf.tcl
/scripts/synth/libero/sgen_dftcompact_2048_4x18_rambuf_pf.tcl
/docs/corefft-porting-and-simulation-report.md

# Logs and misc tool output
/*.log
/*.jou
/*.pb
/*.zip
